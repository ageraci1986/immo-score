# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Database
DATABASE_URL=postgresql://postgres.your-project-id:your_password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-xxx

# Upstash Redis (for rate limiting and caching)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# Sentry (optional - for error monitoring)
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=xxx

# Application URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Environment
NODE_ENV=development
LOG_LEVEL=info

# Feature Flags (optional)
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_E2E_TESTS=false

# =============================================================================
# PREMIUM PROXY CONFIGURATION - IMPORTANT FOR IMMOWEB SCRAPING
# =============================================================================
# Configure at least ONE premium proxy service below to bypass IP blocks
# Residential proxies work best for avoiding detection on Immoweb.be
# =============================================================================

# Option 1: Bright Data (formerly Luminati) - BEST for avoiding detection
# Website: https://brightdata.com/
# Pricing: ~$8.40/GB residential, free trial available
# BRIGHTDATA_USERNAME=your_username
# BRIGHTDATA_PASSWORD=your_password

# Option 2: Oxylabs - High quality residential proxies
# Website: https://oxylabs.io/
# Pricing: ~$8/GB residential, free trial available
# OXYLABS_USERNAME=your_username
# OXYLABS_PASSWORD=your_password

# Option 3: Smartproxy - Good balance of price/quality
# Website: https://smartproxy.com/
# Pricing: ~$7/GB residential, free trial available
# SMARTPROXY_USERNAME=your_username
# SMARTPROXY_PASSWORD=your_password

# Option 4: IPRoyal - Budget residential proxies (RECOMMENDED)
# Website: https://iproyal.com/
# Pricing: ~$2/GB residential, very affordable
# IPROYAL_USERNAME=your_username
# IPROYAL_PASSWORD=your_password

# Option 5: Proxy-Seller - Budget datacenter proxies
# Website: https://proxy-seller.com/
# Pricing: ~$1.77/proxy/month, good for light usage
# PROXYSELLER_HOST=123.45.67.89
# PROXYSELLER_PORT=8080
# PROXYSELLER_USERNAME=your_username
# PROXYSELLER_PASSWORD=your_password

# Option 6: WebShare - Cheapest datacenter proxies (BEST VALUE)
# Website: https://www.webshare.io/
# Pricing: $2.99/month for 10 proxies
# Format: user:pass@host:port,user:pass@host:port,...
# WEBSHARE_PROXY_LIST=user1:pass1@proxy1.webshare.io:80,user2:pass2@proxy2.webshare.io:80

# Option 7: ScraperAPI - Proxy + scraping service
# Website: https://www.scraperapi.com/
# Pricing: Free tier: 1000 requests/month, paid plans from $49/month
# SCRAPERAPI_KEY=your_api_key

# Option 8: Custom proxy (any HTTP/HTTPS proxy)
# CUSTOM_PROXY_URL=http://username:password@proxy.example.com:8080

# =============================================================================
# RECOMMENDATION FOR IMMOWEB SCRAPING
# =============================================================================
# Your IP may be blocked by Immoweb
# You need a premium proxy to continue scraping
#
# BEST OPTIONS:
# 1. IPRoyal Residential (~$7 for 1000 requests) - Most reliable
# 2. WebShare Datacenter ($2.99/month) - Best value
# 3. Bright Data (7-day trial) - Best quality but expensive
